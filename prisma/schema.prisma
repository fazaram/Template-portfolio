generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Profile {
  id           String   @id @default(cuid())
  name         String
  role         String
  bio          String
  email        String
  typingTexts  String
  githubUrl    String?
  linkedinUrl  String?
  twitterUrl   String?
  updatedAt    DateTime @updatedAt
  avatarUrl    String?
  awardsWon    String?  @default("12")
  clientsHappy String?  @default("25+")
  projectsDone String?  @default("40+")
  yearsExp     String?  @default("5+")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String
  link        String?
  tags        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id          String   @id @default(cuid())
  role        String
  company     String
  period      String
  description String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
